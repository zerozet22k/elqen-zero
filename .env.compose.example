# Copy to .env before running `docker compose up --build`

MONGO_DB=elqen_zero

CLIENT_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
SOCKET_ORIGIN=http://localhost:3000
PUBLIC_WEBHOOK_BASE_URL=http://localhost:4000

REDIS_REQUIRED=true
JWT_SECRET=change-me
SESSION_SECRET=change-me
FIELD_ENCRYPTION_KEY=change-me
LOG_LEVEL=info

APP_TENANT_MODE=multi
ALLOW_SELF_SIGNUP=true
ALLOW_WORKSPACE_CREATION=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
OPENAI_MODEL=gpt-5.3-codex
OPENAI_API_BASE_URL=https://api.openai.com/v1

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=

META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
